{
   "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "ignoreUnknown": true,
      "includes": [
         "**",
         "!!.next",
         "!!node_modules",
         "!!out",
         "!!build",
         "!!next-env.d.ts",
         "!!src/types/database.ts"
      ]
   },
   "formatter": {
      "enabled": true,
      "lineWidth": 100,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineEnding": "lf"
   },
   "javascript": {
      "formatter": {
         "quoteStyle": "single",
         "trailingCommas": "all",
         "semicolons": "always",
         "bracketSpacing": true,
         "bracketSameLine": false,
         "arrowParentheses": "asNeeded"
      }
   },
   "linter": {
      "enabled": true,
      "rules": {
         "recommended": true,
         "correctness": {
            "noUnusedImports": {
               "fix": "safe",
               "level": "error"
            },
            "useExhaustiveDependencies": {
               "level": "error"
            }
         },
         "suspicious": {
            "noConsole": {
               "level": "warn"
            },
            "noExplicitAny": {
               "level": "error"
            }
         }
      }
   },
   "assist": {
      "enabled": true,
      "actions": {
         "source": {
            "organizeImports": "on"
         }
      }
   },
   "overrides": [
      {
         "includes": ["src/components/VolumeControl/index.tsx"],
         "linter": {
            "rules": {
               "a11y": {
                  "useSemanticElements": "off"
               }
            }
         }
      },
      {
         "includes": ["scripts/**", "e2e/**"],
         "linter": {
            "rules": {
               "suspicious": {
                  "noConsole": "off"
               }
            }
         }
      },
      {
         "includes": ["src/lib/logger.ts"],
         "linter": {
            "rules": {
               "suspicious": {
                  "noConsole": "off"
               }
            }
         }
      }
   ]
}
